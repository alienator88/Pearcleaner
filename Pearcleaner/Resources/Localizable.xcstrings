    "Add files or folders that will be ignored when searching for orphaned files. Click a path to remove it from the list." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "添加在扫描残留文件时想要忽略的文件或文件夹。点击路径可以从列表中删除。"
          }
        }
      }
    },
